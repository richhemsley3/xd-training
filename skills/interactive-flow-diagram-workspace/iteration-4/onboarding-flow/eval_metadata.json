      "name": "SDS dark text",
      "text": "#1C1A17"
    },
    {
      "type": "contains",
      "name": "SVG rendering",
      "text": "<svg"
    },
    {
      "type": "contains",
      "name": "Click interaction",
      "text": "click"
    },
    {
      "type": "contains",
      "name": "Zoom behavior",
      "text": "zoom"
